#!/usr/bin/env bash

echo "Setting profile for docker"

alias ll='ls -la'
export MOUNT_DIR="/mnt/kmttg"
export USER_ID=$(id -u kmttg)
export GROUP_ID=$(id -g kmttg)
export KMTTG_TOOLS_DIR="/usr/local/bin"
export KMTTG_OUTPUT_DIR="${MOUNT_DIR}/output"

umask 000
doas rc-service dbus restart
doas rc-update add avahi-daemon
sleep 1
doas rc-service avahi-daemon start
doas chmod -R a+rwx /mnt/kmttg
